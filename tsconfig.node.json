{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "target": "ES2020",
    "types": ["node"]
  },
  "include": ["vite.config.ts", "src/main.ts", "src/preload.ts"]
}