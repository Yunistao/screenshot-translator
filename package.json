{
  "name": "screenshot-translator",
  "version": "1.0.0",
  "description": "A screenshot translation tool with OCR and translation functionality",
  "main": "dist-electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "npm run build:main && concurrently \"npm run build:watch\" \"vite\" \"wait-on -t 60000 http://localhost:5173 && electron .\"",
    "dev:vite": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build:watch": "tsc -w",
    "postinstall": "electron-builder install-app-deps",
    "pack": "electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "test:e2e": "npm run build:main && playwright test -c playwright.electron.config.ts",
    "test:e2e:headed": "npm run build:main && playwright test -c playwright.electron.config.ts --headed"
  },
  "keywords": [
    "screenshot",
    "translation",
    "ocr",
    "electron"
  ],
  "author": "Claude Code",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "@types/node": "^20.11.17",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/spark-md5": "^3.0.5",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "playwright": "^1.53.2",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@azure-rest/ai-translation-text": "^1.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.1",
    "spark-md5": "^3.0.2",
    "tesseract.js": "^5.0.5",
    "zustand": "^4.5.0"
  },
  "build": {
    "appId": "com.claude.screenshot-translator",
    "productName": "Screenshot Translator",
    "directories": {
      "output": "release"
    },
    "files": [
        "dist/**/*",
		  "dist-electron/**/*",
		  "node_modules/**/*",
		  "package.json",
		  "public/icon.png"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png",
      "publisherName": "Claude Code"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/icons",
      "category": "Graphics"
    }
  }
}
